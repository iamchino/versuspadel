# ── Versus Padel — Environment Variables Template ──────────────
# Copy this file to .env and fill in the values.
# .env is in .gitignore and will NEVER be committed to GitHub.
# In production, these are injected via GitHub Actions Repository Secrets.

# WooCommerce Store URL (WordPress installation root)
# Production: https://api.versuspadel.ar
VITE_WC_URL=http://localhost:10011

# WooCommerce REST API Credentials
# Generate at: WooCommerce > Settings > Advanced > REST API
# ⚠️  VITE_ prefix = included in browser bundle. Use only for trusted environments.
VITE_WC_CONSUMER_KEY=ck_your_consumer_key_here
VITE_WC_CONSUMER_SECRET=cs_your_consumer_secret_here

# Admin panel access password (for /admin route)
ADMIN_PASSWORD=your_admin_password_here
