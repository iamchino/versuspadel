# Block access to config and middleware files (contain secrets/logic)
<FilesMatch "^(config|middleware)\.php$">
    Require all denied
</FilesMatch>

# Block access to TypeScript source files
<FilesMatch "\.(ts|tsx)$">
    Require all denied
</FilesMatch>

# Only allow PHP files to be executed
<FilesMatch "\.php$">
    Require all granted
</FilesMatch>
