# ── Force index.html over index.php (React over WordPress) ──
DirectoryIndex index.html

# Enable URL rewriting
RewriteEngine On

# ── Proteger /api/ (WordPress + WooCommerce) ──────────────────
# Si la ruta empieza con api/, no tocar nada — dejar que Apache/WordPress lo maneje
RewriteCond %{REQUEST_URI} ^/api/ [NC]
RewriteRule ^ - [L]

# ── Proteger /backend/ (PHP proxy) ───────────────────────────
RewriteCond %{REQUEST_URI} ^/backend/ [NC]
RewriteRule ^ - [L]

# ── Proteger archivos de WordPress en raiz ────────────────────
RewriteRule ^wp- - [L]
RewriteRule ^xmlrpc\.php$ - [L]

# ── Si es un archivo o carpeta real, servirlo directamente ────
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ── SPA fallback: todo lo demas va a React ────────────────────
RewriteRule ^ /index.html [L]

# ── Security Headers ──────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ── Compression ───────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ── Browser Caching ───────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType text/html "access plus 10 minutes"
</IfModule>
